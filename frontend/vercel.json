{
  "routes": [
    { "src": "/portal/(.*)", "dest": "https://www.beastassociate.com/portal/$1" },
    { "src": "/api/(.*)", "dest": "https://www.beastassociate.com/api/$1" },
    { "src": "/p/(.*)", "dest": "https://www.beastassociate.com/p/$1?xfh=us" },
    { "src": "/go/(.*)", "dest": "https://www.beastassociate.com/go/$1" },
    { "src": "/b/(.*)", "dest": "https://www.beastassociate.com/b/$1" },
    { "src": "/u/(.*)", "dest": "https://www.beastassociate.com/u/$1" },

    { "src": "/", "dest": "https://www.beastassociate.com/?xfh=aff" },
    {
      "src": "/(articles|about|contact|privacy|terms)",
      "dest": "https://www.beastassociate.com/$1?xfh=aff"
    },

    { "handle": "filesystem" },

    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
