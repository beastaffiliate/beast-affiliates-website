{
  "rewrites": [
    { "source": "/portal/(.*)", "destination": "https://www.beastassociate.com/portal/$1" },
    { "source": "/api/(.*)", "destination": "https://www.beastassociate.com/api/$1" },
    { "source": "/p/(.*)", "destination": "https://www.beastassociate.com/p/$1" },
    { "source": "/go/(.*)", "destination": "https://www.beastassociate.com/go/$1" },
    { "source": "/b/(.*)", "destination": "https://www.beastassociate.com/b/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
