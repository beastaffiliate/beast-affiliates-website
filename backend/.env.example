# Copy to .env for local dev; in production set these in the Vercel project.

# Neon Postgres connection string (leave empty locally -> SQLite file)
DATABASE_URL=

# Shared secret for POST /api/links (bot backend -> website). Generate a long
# random string. Empty = open API (local dev only).
SERVICE_KEY=

# Article URL bases (env-driven so dev/test can point at localhost)
ARTICLE_BASE_US=https://beastaffiliates.com
ARTICLE_BASE_INTL=https://beastassocoate.com

DEFAULT_STORE_NAME=Beast Affiliates

# PA-API v5 credentials per marketplace (from each Amazon account's
# "credentials.csv" download + that account's store/partner tag).
# Leave a marketplace blank to use the scrape fallback for it (e.g. NL).
PAAPI_US_ACCESS_KEY=
PAAPI_US_SECRET_KEY=
PAAPI_US_PARTNER_TAG=
PAAPI_UK_ACCESS_KEY=
PAAPI_UK_SECRET_KEY=
PAAPI_UK_PARTNER_TAG=
PAAPI_CA_ACCESS_KEY=
PAAPI_CA_SECRET_KEY=
PAAPI_CA_PARTNER_TAG=
PAAPI_DE_ACCESS_KEY=
PAAPI_DE_SECRET_KEY=
PAAPI_DE_PARTNER_TAG=
PAAPI_FR_ACCESS_KEY=
PAAPI_FR_SECRET_KEY=
PAAPI_FR_PARTNER_TAG=
PAAPI_IT_ACCESS_KEY=
PAAPI_IT_SECRET_KEY=
PAAPI_IT_PARTNER_TAG=
PAAPI_ES_ACCESS_KEY=
PAAPI_ES_SECRET_KEY=
PAAPI_ES_PARTNER_TAG=
PAAPI_NL_ACCESS_KEY=
PAAPI_NL_SECRET_KEY=
PAAPI_NL_PARTNER_TAG=
PAAPI_AU_ACCESS_KEY=
PAAPI_AU_SECRET_KEY=
PAAPI_AU_PARTNER_TAG=
