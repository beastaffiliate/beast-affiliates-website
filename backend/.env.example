# Copy to .env for local dev; in production set these in the Vercel project.

# Neon Postgres connection string (leave empty locally -> SQLite file)
DATABASE_URL=

# Shared secret for POST /api/links (bot backend -> website). Generate a long
# random string. Empty = open API (local dev only).
SERVICE_KEY=

# --- Portal (Phase 3) ---
# The bot API base + its service key, so the portal can verify a WhatsApp
# number is a registered bot user and proxy profile/preference changes.
# BOT_SERVICE_KEY must equal HUB_SERVICE_KEY set on the bot API project.
BOT_API_URL=https://amazon-link-whatsappbot-client.vercel.app
BOT_SERVICE_KEY=
# Signing secret for portal login tokens. Set any long random string in prod
# (if unset it derives from SERVICE_KEY, which also works but rotate-together).
PORTAL_SECRET=

# Article URL bases (env-driven so dev/test can point at localhost)
ARTICLE_BASE_US=https://beastaffiliates.com
ARTICLE_BASE_INTL=https://beastassociate.com

DEFAULT_STORE_NAME=Beast Affiliates

# Product data comes from SCRAPING by default (owner decision 2026-07-16).
# Set USE_PAAPI=true (plus credentials below) to put PA-API in front of the
# scraper — no code change needed.
USE_PAAPI=false

# PA-API v5 credentials per marketplace — ONLY used when USE_PAAPI=true.
PAAPI_US_ACCESS_KEY=
PAAPI_US_SECRET_KEY=
PAAPI_US_PARTNER_TAG=
PAAPI_UK_ACCESS_KEY=
PAAPI_UK_SECRET_KEY=
PAAPI_UK_PARTNER_TAG=
PAAPI_CA_ACCESS_KEY=
PAAPI_CA_SECRET_KEY=
PAAPI_CA_PARTNER_TAG=
PAAPI_DE_ACCESS_KEY=
PAAPI_DE_SECRET_KEY=
PAAPI_DE_PARTNER_TAG=
PAAPI_FR_ACCESS_KEY=
PAAPI_FR_SECRET_KEY=
PAAPI_FR_PARTNER_TAG=
PAAPI_IT_ACCESS_KEY=
PAAPI_IT_SECRET_KEY=
PAAPI_IT_PARTNER_TAG=
PAAPI_ES_ACCESS_KEY=
PAAPI_ES_SECRET_KEY=
PAAPI_ES_PARTNER_TAG=
PAAPI_NL_ACCESS_KEY=
PAAPI_NL_SECRET_KEY=
PAAPI_NL_PARTNER_TAG=
PAAPI_AU_ACCESS_KEY=
PAAPI_AU_SECRET_KEY=
PAAPI_AU_PARTNER_TAG=
